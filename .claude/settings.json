{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force-if-includes:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh repo delete:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(wget:* | sh)",
      "Bash(wget:* | bash)",
      "Bash(sudo:*)",
      "Bash(npx:*)",
      "Bash(bunx:*)",
      "Bash(pnpm dlx:*)",
      "Bash(npm dlx:*)",
      "Bash(yarn dlx:*)",
      "Bash(pnpm add:*)",
      "Bash(npm add:*)",
      "Bash(yarn add:*)",
      "Bash(bun add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm uninstall:*)",
      "Bash(pnpm update:*)",
      "Bash(pnpm upgrade:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm update:*)",
      "Bash(yarn remove:*)",
      "Bash(yarn upgrade:*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./.claude/settings.json)",
      "Edit(./.claude/settings.local.json)",
      "Edit(./.claude/hooks/**)",
      "Edit(./.claude/agents/**)",
      "Edit(./.github/workflows/**)",
      "Edit(./package.json)",
      "Edit(./pnpm-lock.yaml)",
      "Edit(./package-lock.json)",
      "Edit(./yarn.lock)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./.claude/settings.json)",
      "Write(./.claude/settings.local.json)",
      "Write(./.claude/hooks/**)",
      "Write(./.claude/agents/**)",
      "Write(./.github/workflows/**)",
      "Write(./package.json)",
      "Write(./pnpm-lock.yaml)",
      "Write(./package-lock.json)",
      "Write(./yarn.lock)"
    ],
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm install --frozen-lockfile:*)",
      "Bash(pnpm install --offline:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue close:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(echo:*)",
      "Bash(node:*)",
      "Bash(which:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/bash-guard.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/write-guard.js"
          }
        ]
      }
    ]
  }
}
